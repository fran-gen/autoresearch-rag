# Google Gemini API key (either name works)
GOOGLE_API_KEY=your_google_api_key
# GEMINI_API_KEY=your_google_api_key

GEMINI_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
QDRANT_PATH=./index/qdrant_data
BENCHMARK_ROOT=./data
EXPERIMENT_DB_PATH=./data/experiments.db
DEFAULT_TOP_K=8
FLASK_SECRET_KEY=change-me-to-a-random-string
KINDE_ISSUER_URL = "https://yoururl.kinde.com"
KINDE_CALLBACK_URL = "http://localhost:8501/callback"
LOGOUT_REDIRECT_URL = "http://localhost:8501"
KINDE_CLIENT_ID = "yourclientid"
KINDE_CLIENT_SECRET = "yourclientsecret"
